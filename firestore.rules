rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isTeacher() { return signedIn() && role() == 'teacher'; }
    function isAdmin() {
      return signedIn() &&
        (request.auth.token.email == 'im.iskandartony@gmail.com' || role() == 'admin');
    }
    function isParentOf(uid) {
      return signedIn() &&
        exists(/databases/$(database)/documents/parents/$(request.auth.uid)) &&
        uid in get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.children;
    }

    // Student profiles: owner read/write; parents & teachers read; role is immutable by owner.
    match /users/{uid} {
      allow read: if isSelf(uid) || isParentOf(uid) || isTeacher() || isAdmin();
      allow create: if isSelf(uid)
        && request.resource.data.role in ['student', 'parent', 'teacher']
        && request.resource.data.xp == 0 && request.resource.data.coins <= 100
        && request.resource.data.premium == false;
      // Premium is granted server-side only (payments webhook via Admin SDK,
      // which bypasses these rules) — a signed-in user can never flip it
      // themselves, even through a merge write. get(key, default) is required
      // here: accounts created before this field existed have no `premium`
      // key at all, and dot-accessing a truly missing map key throws in
      // Firestore rules (denying the write) instead of reading as false.
      allow update: if (isSelf(uid) && request.resource.data.role == resource.data.role
          && request.resource.data.get('premium', false) == resource.data.get('premium', false))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // Family-link codes: student publishes their own code; any signed-in
    // adult can look one up (needs the exact 6-char code, not listable).
    match /codes/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /parents/{uid} {
      allow read, write: if isSelf(uid) || isAdmin();
    }

    match /teachers/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow write: if isAdmin();
      match /classes/{classId} {
        // The teacher who owns this class has full access.
        allow read: if isSelf(uid) || isAdmin();
        // A joined student (their own uid already sits in studentUids) may
        // also read the class doc — needed for the collectionGroup query on
        // the student's own dashboard/settings. Kept as its own statement
        // (rather than OR'd into the one above) because Firestore validates
        // collection-group queries per `allow` statement: a plain field
        // containment check like this one is provably safe for the
        // `where('studentUids','array-contains', uid)` query regardless of
        // the other statement's get()-based isAdmin() check, but merged into
        // one compound OR the whole expression can become unprovable and the
        // query gets rejected outright with "Missing or insufficient
        // permissions" instead of just filtering out non-matching docs.
        allow read: if signedIn() && request.auth.uid in resource.data.studentUids;
        allow create, delete: if isSelf(uid) || isAdmin();
        allow update: if isSelf(uid) || isAdmin() || (
          signedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentUids'])
          && request.resource.data.studentUids.size() == resource.data.studentUids.size() + 1
          && request.auth.uid in request.resource.data.studentUids
        );
      }
    }

    // Class-join codes: teacher publishes one per class; any signed-in
    // student can look one up (needs the exact 6-char code, not listable).
    match /classCodes/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if isTeacher() && request.resource.data.teacherUid == request.auth.uid;
      // A teacher can delete/republish their own class's code pointer (used to
      // archive/unarchive a class without touching the code students already have).
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isTeacher() && resource.data.teacherUid == request.auth.uid);
    }

    // Curriculum content: readable by all signed-in users, writable by admin only.
    match /lessons/{id}   { allow read: if signedIn(); allow write: if isAdmin(); }
    match /quizzes/{id}   { allow read: if signedIn(); allow write: if isAdmin(); }
    match /worlds/{id}    { allow read: if signedIn(); allow write: if isAdmin(); }
    match /rewards/{id}   { allow read: if signedIn(); allow write: if isAdmin(); }
    match /missions/{id}  { allow read: if signedIn(); allow write: if isAdmin(); }

    // Admin-customizable icons (worlds, bosses, pets, achievements, app icon).
    // One shared document; read by everyone, written by admin only.
    match /assetOverrides/{doc} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Leaderboards: read-only to clients; written by trusted tooling/admin.
    match /leaderboards/{id} { allow read: if signedIn(); allow write: if isAdmin(); }

    // Public scoreboard mirror: each student writes only their own slim entry.
    match /leaderboard/{uid} {
      allow read: if signedIn();
      allow write: if isSelf(uid)
        && request.resource.data.keys().hasOnly(['name', 'xp']);
      allow delete: if isAdmin();
    }

    // Online Friend Duel: a private two-player room found only by its exact
    // 6-char code (not listable), same trust model as family-link codes.
    // Field-level write policing is intentionally loose here — this is a
    // casual, no-stakes, invite-only match between two consenting kids who
    // already share a private code, not a graded or monetary system.
    match /duels/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.guestUid == null
        && request.resource.data.status == 'waiting'
        && request.resource.data.currentRound == 0;
      allow update: if signedIn() && (
        (resource.data.guestUid == null && request.resource.data.guestUid == request.auth.uid) ||
        request.auth.uid == resource.data.hostUid ||
        request.auth.uid == resource.data.guestUid
      );
      allow delete: if isAdmin();
    }

    // Assignments: teacher creates, assigned students read.
    match /assignments/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    // Analytics events: students append their own; teachers/admin read.
    match /analytics/{id} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isTeacher() || isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /{document=**} { allow read, write: if false; }
  }
}
